# Copy to `.env` on the deploy host. Do NOT commit `.env`.
# These vars are ONLY used by docker-compose to launch containers.
# The .NET app reads MinIO config from appsettings.{Staging,Production}.json.

VENDLY_PROD_IMAGE=ghcr.io/your-org/vendly-server:prod-latest
VENDLY_STAGE_IMAGE=ghcr.io/your-org/vendly-server:stage-latest

# MinIO admin credentials. Must MATCH the AccessKey/SecretKey in
# appsettings.Production.json AND appsettings.Staging.json.
# Both stage and prod app containers connect to the SAME MinIO instance,
# but use different buckets (prod-vendly vs stage-vendly).
MINIO_ROOT_USER=vendlyadmin
MINIO_ROOT_PASSWORD=rI0eSKvglRFjLz0TxhrlBB5I0boruQnf
